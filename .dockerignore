# ── Version control ──────────────────────────────────────────────────────────
.git
.gitignore

# ── Secrets / local env ───────────────────────────────────────────────────────
.env
*.env
backend/.env
frontend/.env

# ── Python ────────────────────────────────────────────────────────────────────
