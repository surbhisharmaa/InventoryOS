backend/seed.py

# ── Node / Frontend ───────────────────────────────────────────────────────────
frontend/node_modules/
frontend/dist/
frontend/.cache/

# ── IDE / OS ─────────────────────────────────────────────────────────────────
.vscode/
.idea/
*.DS_Store
Thumbs.db
